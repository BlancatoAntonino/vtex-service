{
  "memory": 128,
  "ttl": 10,
  "timeout": 10,
  "minReplicas": 2,
  "maxReplicas": 10,
  "workers": 4,
  "events": {
    "liveUsersUpdate": {
      "sender": "replyqa1.events-example",
      "keys": ["send-event"]
    }
  },
  "principals": [
  "vrn:apps:*:*:*:app/vtex.backend-course@*",
  "vrn:apps:*:*:*:app/vtex.events-example@*",
  "vrn:apps:*:*:*:app/replyqa1.backend-course@*"
  ],
  "routes": {
    "analytics": {
      "path": "/_v/app/analytics/realTime",
      "public": true
    },
    "status": {
      "path": "/_v/status/:code",
      "public": true
    }
  }
}
